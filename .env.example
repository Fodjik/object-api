# Public URL of your Supabase project (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co

# anon public key — safe to expose to the browser; used to validate JWTs
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — NEVER expose to clients; only on Render/server
# Required for: QR public object lookup, listing users, approving users, deleting auth users
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional (defaults to 3000)
PORT=3000

# Public URL of your deployed app (no trailing slash). Set on Render so magic-link emails use this host.
# Example: https://your-service.onrender.com
PUBLIC_SITE_URL=

# Legacy: if you still use a single SUPABASE_KEY, set SUPABASE_ANON_KEY to the anon key
# and add SUPABASE_SERVICE_ROLE_KEY separately.
